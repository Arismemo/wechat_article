APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
API_PORT=8000
APP_BASE_URL=https://example.com
LOG_LEVEL=INFO
TIMEZONE=Asia/Shanghai

API_BEARER_TOKEN=replace-me
API_HMAC_SECRET=

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/wechat_artical
