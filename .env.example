LLM_MODEL_ANALYZE=glm-5
LLM_MODEL_WRITE=glm-5
LLM_MODEL_REVIEW=glm-5
LLM_TIMEOUT_SECONDS=60

SEARCH_PROVIDER=ZHIPU_MCP
SEARCH_API_BASE=https://open.bigmodel.cn/api/mcp/web_search_prime/mcp
SEARCH_API_KEY=replace-me
SEARCH_TIMEOUT_SECONDS=30
FETCH_HTTP_TIMEOUT_SECONDS=25
FETCH_BROWSER_TIMEOUT_SECONDS=45
FETCH_USER_AGENT=Mozilla/5.0\ (iPhone;\ CPU\ iPhone\ OS\ 17_0\ like\ Mac\ OS\ X)\ AppleWebKit/605.1.15\ (KHTML,\ like\ Gecko)\ Mobile/15E148\ MicroMessenger
MAX_SOURCE_EXCERPT_CHARS=1200
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER_CHANNELS=chromium,chrome
PLAYWRIGHT_VIEWPORT_WIDTH=430
PLAYWRIGHT_VIEWPORT_HEIGHT=932
WECHAT_EXPORTER_BASE_URL=
WECHAT_EXPORTER_REQUEST_TIMEOUT_SECONDS=30

WECHAT_APP_ID=wxa51f35e4cc384e6e
WECHAT_APP_SECRET=replace-me
WECHAT_API_BASE=https://api.weixin.qq.com/cgi-bin
WECHAT_TOKEN_CACHE_KEY=wechat:token
WECHAT_ENABLE_DRAFT_PUSH=false
WECHAT_DEFAULT_AUTHOR=
WECHAT_DEFAULT_DIGEST_PREFIX=
WECHAT_REQUEST_TIMEOUT_SECONDS=30
WECHAT_INLINE_IMAGE_MAX_BYTES=1000000
PHASE2_INCLUDE_SOURCE_IMAGES=true
PHASE2_MAX_INLINE_IMAGES=3
PHASE2_QUEUE_KEY=phase2:queue
PHASE2_PROCESSING_KEY=phase2:processing
PHASE2_PENDING_SET_KEY=phase2:pending
PHASE2_WORKER_POLL_TIMEOUT_SECONDS=5
PHASE2_WORKER_IDLE_SLEEP_SECONDS=1

LOCAL_STORAGE_ROOT=./data
