[Unit]
Description=wechat_artical feedback sync (oneshot enqueue recent)
After=network-online.target postgresql.service redis-server.service redis.service
Wants=network-online.target

[Service]
Type=oneshot
User=__RUN_USER__
WorkingDirectory=__PROJECT_DIR__
ExecStart=__PROJECT_DIR__/.venv/bin/python __PROJECT_DIR__/scripts/enqueue_recent_feedback.py
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
